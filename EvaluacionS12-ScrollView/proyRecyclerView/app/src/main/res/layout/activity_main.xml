<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tvtitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="FRUTAS"
        android:textSize="40sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/scrollView2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvtitulo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/imageButton1"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:src="@drawable/fresita"
                android:tag="Fresa"
                android:onClick="presionar"
                android:scaleType="centerInside"/>

            <ImageButton
                android:id="@+id/imageButton2"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:src="@drawable/kiwi"
                android:tag="Kiwi"
                android:onClick="presionar"
                android:scaleType="centerInside"
                android:layout_marginTop="10dp"/>

            <ImageButton
                android:id="@+id/imageButton3"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:src="@drawable/manzana"
                android:tag="Manzana"
                android:onClick="presionar"
                android:scaleType="centerInside"
                android:layout_marginTop="10dp"/>

            <ImageButton
                android:id="@+id/imageButton4"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:src="@drawable/melon"
                android:tag="Melon"
                android:onClick="presionar"
                android:scaleType="centerInside"
                android:layout_marginTop="10dp"/>

            <ImageButton
                android:id="@+id/imageButton5"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:src="@drawable/naranja"
                android:tag="Naranja"
                android:onClick="presionar"
                android:scaleType="centerInside"
                android:layout_marginTop="10dp"/>

            <ImageButton
                android:id="@+id/imageButton6"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:src="@drawable/papaya"
                android:tag="Papaya"
                android:onClick="presionar"
                android:scaleType="centerInside"
                android:layout_marginTop="10dp"/>

            <ImageButton
                android:id="@+id/imageButton7"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:src="@drawable/pina"
                android:tag="Piña"
                android:onClick="presionar"
                android:scaleType="centerInside"
                android:layout_marginTop="10dp"/>

            <ImageButton
                android:id="@+id/imageButton8"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:src="@drawable/platano"
                android:tag="Platano"
                android:onClick="presionar"
                android:scaleType="centerInside"
                android:layout_marginTop="10dp"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>